# Environment
PORT=3001
NODE_ENV=development

# Database (Phase 1 - coming soon)
DATABASE_URL=postgresql://user:password@localhost:5432/mabrik_scraper

# Redis (Phase 2 - coming soon)
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-to-a-real-secret
JWT_REFRESH_SECRET=change-me-to-another-real-secret
AUTH_REQUIRE_VERIFIED_EMAIL=false
AUTH_ENABLE_MFA=false
AUTH_ENABLE_SESSION_MANAGEMENT=true
AUTH_MFA_ENCRYPTION_KEY=replace-with-a-long-random-string
AUTH_CSRF_TOKEN_TTL_HOURS=24
AUTH_EMAIL_VERIFICATION_TTL_HOURS=24
AUTH_PASSWORD_RESET_TTL_MINUTES=30
AUTH_MFA_CHALLENGE_TTL_MINUTES=10

# Email (Phase 2 - coming soon)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
