NODE_ENV=development
LOG_LEVEL=info
PORT=3001
TRUST_PROXY_HOPS=0
RATE_LIMIT_REDIS_ENABLED=false
FRONTEND_URL=http://localhost:5173
DATABASE_URL=postgresql://mabrik:mabrik@localhost:5432/mabrik_scraper?schema=public
REDIS_URL=redis://localhost:6379
SCHEDULER_CRON=* * * * *
SCRAPE_WORKER_CONCURRENCY=1
EMAIL_PROVIDER=smtp
EMAIL_FROM=no-reply@example.com
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
RESEND_API_KEY=
JWT_SECRET=replace-with-a-long-random-string-of-at-least-32-characters
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string-of-at-least-32-characters
AUTH_REQUIRE_VERIFIED_EMAIL=false
AUTH_ENABLE_MFA=false
AUTH_ENABLE_SESSION_MANAGEMENT=true
AUTH_MFA_ENCRYPTION_KEY=replace-with-a-long-random-string-of-at-least-32-characters
AUTH_CSRF_TOKEN_TTL_HOURS=24
AUTH_EMAIL_VERIFICATION_TTL_HOURS=24
AUTH_PASSWORD_RESET_TTL_MINUTES=30
AUTH_MFA_CHALLENGE_TTL_MINUTES=10
SCRAPER_REQUEST_TIMEOUT_MS=15000
SCRAPER_RETRY_COUNT=3
SCRAPER_MIN_DELAY_MS=1000
SCRAPER_MAX_DELAY_MS=2000
SCRAPER_ADAPTIVE_DELAY_MAX_MS=10000
SCRAPER_ADAPTIVE_PENALTY_MS=500
SCRAPER_RETRY_BUDGET_MS=900000
SCRAPER_ROBOTS_FETCH_TIMEOUT_MS=5000
SCRAPER_ROBOTS_CACHE_TTL_MS=21600000
SCRAPER_ROBOTS_STRICT=false
